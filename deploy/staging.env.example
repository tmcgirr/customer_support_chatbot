# Copy to deploy/staging.env ON THE DROPLET (gitignored — never commit).
# ENV=staging enforces config validation: every value below must be real, or the
# api container refuses to boot. MONGO_URI is set by the compose file (the mongo
# service), so it is not repeated here.

# Model provider (staging OpenAI project — separate from production, invariant 14)
# Startup default: "openai" or "anthropic". Admins switch at runtime in the portal, but
# only among key-configured providers. Set ANTHROPIC_API_KEY to make Claude selectable
# (required if MODEL_PROVIDER=anthropic). OpenAI stays required (insights embeddings).
MODEL_PROVIDER=openai
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_MODEL=gpt-5.4-mini
OPENAI_VECTOR_STORE_ID=vs_REPLACE_ME
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5   # low-cost tier (~$1/$5 per 1M)

# Secrets — generate real random values (e.g. `openssl rand -hex 32`)
SESSION_SECRET=REPLACE_WITH_RANDOM
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_RANDOM

# Real host origins for the widget (comma-separated) — NOT localhost
CORS_ORIGINS=https://staging.example.com

# Client portal (real staging URL if available)
PORTAL_URL=https://portal.cadreai.com

# Build stamp (optional; set from CI/git for /healthz deploy verification)
BUILD_SHA=unknown
