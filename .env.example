# Copy to backend/.env (gitignored) and fill in real values.
# The backend reads .env from its own working directory (run uvicorn from backend/).

# ENV: "dev" (default) allows the placeholder secrets below. ANY other value
# makes startup FAIL if SESSION_SECRET or ADMIN_PASSWORD is still a default.
ENV=dev

# --- Model provider ---
# Which provider answers chat turns at startup: "openai" (default) or "anthropic".
# An admin can switch this at runtime from the admin portal (Governance → Model
# provider); you can only switch TO a provider whose key is set below.
MODEL_PROVIDER=openai
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_MODEL=gpt-5.4-mini
OPENAI_VECTOR_STORE_ID=          # set after scripts/upload_knowledge.py
# Anthropic (Claude) — set the key to make Claude selectable. Required only when
# MODEL_PROVIDER=anthropic. Insights clustering still uses OpenAI embeddings (Anthropic
# has none), so OPENAI_API_KEY stays required regardless of the active chat provider.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5  # low-cost tier (~$1/$5 per 1M); Opus 4.8 is ~$5/$25
ANTHROPIC_FALLBACK_MODEL=        # optional; a DIFFERENT approved model (see prod notes)

# --- Persistence ---
MONGO_URI=mongodb://localhost:27017/cadre_chatbot

# --- Session tokens (HMAC) — CHANGE for any non-dev deploy ---
SESSION_KEY_ID=k1
SESSION_SECRET=dev-only-change-me
SESSION_EXTRA_SECRETS=           # retired keys still trusted: "kid:secret,kid2:secret2"

# --- Admin dashboard (Basic auth) — CHANGE for any non-dev deploy ---
# Non-dev requires a real password of >= 16 chars (no login lockout exists yet — a
# production IdP replaces Basic auth; see docs/SECURITY_REVIEW_V1.md). `openssl rand -hex 24`.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=dev-only-change-me

# --- Client portal (get_portal_information tool) ---
PORTAL_URL=https://portal.cadreai.com

# --- Abuse caps (app-level; the edge CDN/WAF is the volumetric backstop) ---
MESSAGE_CAP=40
MESSAGE_MAX_CHARS=2000
IP_CREATE_CAP=10
IP_CREATE_WINDOW_SECONDS=3600
LOCK_STALE_SECONDS=120
# Chat-turn (LLM) throttle: per-session + per-IP turns per window.
MESSAGE_RATE_CAP=20
MESSAGE_RATE_WINDOW_SECONDS=60
MESSAGE_IP_CAP=60
MESSAGE_IP_WINDOW_SECONDS=60
# Request-submit throttle: per-conversation + per-IP (each submit can fire a delivery).
REQUEST_CONVERSATION_CAP=10
REQUEST_IP_CAP=20
# Per-response model output ceiling (cost / long-stream guard).
OPENAI_MAX_OUTPUT_TOKENS=1500

# --- LLM cost visibility (admin Usage & cost panel) ---
# $/1M-token price overrides merged over the built-in table (app/domain/usage/pricing.py).
# Format: "model:input:output,model2:input:output". Correct the PLACEHOLDER OpenAI rates
# (gpt-5.4-mini/gpt-5.4) here so the panel's $ figures are right. Example:
# LLM_PRICING=gpt-5.4-mini:0.25:2,gpt-5.4:1.25:10
LLM_PRICING=
# Monthly LLM spend budget in USD → a budget bar + a "budget exceeded" alert (0 = disabled).
LLM_MONTHLY_BUDGET_USD=0
# Trusted reverse-proxy hops for client-IP derivation: 1 = Caddy only; set 2 once a
# CDN/WAF fronts Caddy, or the per-IP caps read a spoofable value. CRITICAL to get right.
TRUSTED_PROXY_HOPS=1

# --- Widget build (frontend): production build FAILS if this is unset or "*" ---
# Comma-separated https origins allowed to embed + message the widget iframe.
# VITE_ALLOWED_ORIGINS=https://www.cadreai.com,https://cadreai.com

# --- Widget dev origins (comma-separated; set real host origins in prod) ---
CORS_ORIGINS=http://localhost:5273
