# Copy to deploy/prod.env ON THE PRODUCTION HOST (gitignored — NEVER commit).
# In production, prefer injecting these from a secrets manager (DO App Platform
# secrets / Vault / SOPS-encrypted file) rather than a plaintext file on disk.
#
# ENV=prod enforces the fail-closed config guard: every secret below must be REAL
# (no placeholders, no localhost) or the api refuses to boot. This is intentional —
# a half-configured production deploy never serves traffic.

# --- Managed MongoDB (Atlas vs self-hosted is Engineering's decision, doc 06 §6) ---
# Must be a real, non-localhost URI with credentials. Use a dedicated PRODUCTION
# database, separate from staging (invariant 14). Enforce backups + a tested restore.
MONGO_URI=mongodb+srv://USER:PASS@prod-cluster.example.mongodb.net/cadre_chatbot?retryWrites=true&w=majority

# --- Model provider — PRODUCTION OpenAI project + Vector Store (separate from staging) ---
OPENAI_API_KEY=sk-PROD-REPLACE_ME
OPENAI_MODEL=gpt-5.4-mini
# Fallback MUST be a DIFFERENT approved model than OPENAI_MODEL — the adapter retries
# once on MODEL_UNAVAILABLE, so an identical fallback provides no resilience (invariant
# 15). Validate the chosen fallback with the golden gate. Leave empty to disable fallback.
OPENAI_FALLBACK_MODEL=
OPENAI_VECTOR_STORE_ID=vs_PROD_REPLACE_ME

# --- Secrets — generate strong random values (openssl rand -hex 32) ---
SESSION_SECRET=REPLACE_WITH_RANDOM
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_RANDOM
# Optional read-only viewer login. Leave EMPTY to disable; a placeholder is rejected.
VIEWER_PASSWORD=

# --- Real production widget origins (comma-separated https, NOT localhost) ---
CORS_ORIGINS=https://www.cadre.ai,https://cadre.ai

# --- Client portal (real production URL — Client Success, doc 06 §6) ---
PORTAL_URL=https://portal.cadre.ai

# --- Feature flags ---
ENABLE_DELIVERY=true
# Public citation display — Product/Marketing decision (doc 06 §6). Keep off until approved.
ENABLE_CITATIONS=false

# --- Build stamp (set from CI/git sha for /api/v1/admin/system deploy verification) ---
BUILD_SHA=REPLACE_WITH_GIT_SHA

# --- Retention periods (days) — confirm with Legal/Privacy before launch; must match
#     docs/PRIVACY_NOTICE.md. Uncomment to override the in-code defaults. ---
# RETENTION_ABANDONED_CONVERSATION_DAYS=30
# RETENTION_CONVERSATION_DAYS=365
# RETENTION_REQUEST_DAYS=365
# RETENTION_FEEDBACK_DAYS=365

# --- Caddy TLS host (also passed as PROD_DOMAIN to the compose invocation) ---
PROD_DOMAIN=chat.cadre.ai
